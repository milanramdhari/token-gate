generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int                  @id @default(autoincrement())
  email              String               @unique
  password           String
  credits            Int                  @default(0)
  onrampTransactions onrampTransactions[]
  conversations      Conversation[]
  apiKeys            ApiKey[]
}

model ApiKey {
  id       Int     @id @default(autoincrement())
  userId   Int
  name     String
  apiKey   String
  disables Boolean @default(false)
  deleted  Boolean @default(false)
  user     User    @relation(fields: [userId], references: [id])
}

model Company {
  id      Int     @id @default(autoincrement())
  name    String
  website String
  models  Model[]
}

model Model {
  id        Int     @id @default(autoincrement())
  name      String
  slug      String  @unique
  companyID Int
  company   Company @relation(fields: [companyId], references: [id])
  companyId Int
}
